

# ===== Database Configuration =====
DATABASE_URL=jdbc:mysql://localhost:3306/your_database?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Europe/Kiev&characterEncoding=UTF-8&useUnicode=true&autoReconnect=true&failOverReadOnly=false&maxReconnects=10
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password
DATABASE_DRIVER=com.mysql.cj.jdbc.Driver

# ===== Connection Pool =====
DATABASE_POOL_MAXIMUM=10
DATABASE_POOL_MINIMUM=2
DATABASE_POOL_TIMEOUT=30000

# ===== Google Maps API =====
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_API_URL=https://maps.googleapis.com/maps/api

# ===== Email Configuration (Gmail IMAP) =====
EMAIL_SERVER=imap.gmail.com
EMAIL_PORT=993
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_PROTOCOL=imaps
EMAIL_CHECK_INTERVAL=300000

# ===== Application Settings =====
APPLICATION_TITLE=Система обліку палива
APPLICATION_VERSION=1.0.0
REPORTS_OUTPUT_DIRECTORY=./reports
TEMP_DIRECTORY=./temp

# ===== Fuel Calculation =====
FUEL_CALCULATION_ENABLED=true
FUEL_CALCULATION_SHOW_DETAILS=true

# ===== Route Settings =====
ROUTE_AUTO_CALCULATE=true
ROUTE_CALCULATION_DELAY_MS=2000
