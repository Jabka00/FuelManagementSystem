                                                        <VBox fx:id="purposeBox" spacing="5.0">
                                                            <Label text=" Мета поїздки:" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                            <Label fx:id="lblDetailPurpose" text="-" wrapText="true"
                                                                   style="-fx-font-size: 13px; -fx-background-color: rgba(255,255,255,0.6); -fx-background-radius: 6; -fx-padding: 8;" />
