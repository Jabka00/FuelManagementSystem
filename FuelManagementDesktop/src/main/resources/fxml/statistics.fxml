                     -fx-padding: 10 20;">
            <children>
                <Label fx:id="lblStatus" text="Готово до роботи"
                       style="-fx-font-size: 12px; -fx-text-fill: gray;" />

                <Region HBox.hgrow="ALWAYS" />

                <ProgressIndicator fx:id="progressLoading" visible="false"
