                                                        <VBox fx:id="attorneyBox" spacing="5.0">
                                                            <Label text="📄 Довіреність:" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                            <Label fx:id="lblDetailPowerOfAttorney" text="-" wrapText="true"
                                                                   style="-fx-font-size: 13px; -fx-background-color: rgba(255,255,255,0.6); -fx-background-radius: 6; -fx-padding: 8;" />
                                                        </VBox>

                                                        <HBox fx:id="deliveryBox" spacing="8.0" alignment="CENTER_LEFT">
                                                            <Label text="" style="-fx-font-size: 16px;" />
                                                            <Label fx:id="lblDetailCanDeliver" text="Водій може сам завезти вантаж"
                                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" />
                                                        </HBox>

                                                        <VBox fx:id="notesBox" spacing="5.0">
                                                            <Label text="💬 Примітки:" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                            <TextArea fx:id="txtDetailNotes" wrapText="true" editable="false" prefRowCount="3"
                                                                      style="-fx-font-size: 12px; -fx-background-color: rgba(255,255,255,0.6); -fx-background-radius: 6; -fx-control-inner-background: rgba(255,255,255,0.6);" />
                                                        </VBox>
                                                    </VBox>
                                                </VBox>
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
                </children>
