<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="org.example.fuelmanagement.controller.TripDetailController"
            style="-fx-background-color: #F5F5F5;">
    
    <top>
        <!-- Header -->
        <VBox style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0; -fx-padding: 20;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <children>
                        <Button fx:id="btnBack" onAction="#handleBack"
                                text="←"
                                style="-fx-background-color: transparent; -fx-text-fill: #238A90; -fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 5 10;">
                            <tooltip>
                                <Tooltip text="Повернутися до списку поїздок" />
                            </tooltip>
                        </Button>
                        
                        <VBox spacing="5">
                            <children>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="lblTripNumber" text="Поїздка #" 
                                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                        <Label fx:id="lblStatus" text="Статус"
                                               style="-fx-background-color: #E0E0E0; -fx-padding: 5 12; -fx-background-radius: 15; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px;" />
                                    </children>
                                </HBox>
                                <Label fx:id="lblRouteType" text="Тип маршруту" 
                                       style="-fx-text-fill: #757575; -fx-font-size: 14px;" />
                            </children>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <!-- Action Buttons -->
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnRestore" onAction="#handleRestore" text=" Відновити" visible="false"
                                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;">
                                    <tooltip>
                                        <Tooltip text="Відновити видалену поїздку" />
                                    </tooltip>
                                </Button>
                                
                                <Button fx:id="btnEdit" onAction="#handleEdit" text=" Редагувати"
                                        style="-fx-background-color: transparent; -fx-border-color: #238A90; -fx-border-width: 2; -fx-border-radius: 6; -fx-text-fill: #238A90; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;">
                                    <tooltip>
                                        <Tooltip text="Редагувати маршрут поїздки" />
                                    </tooltip>
                                </Button>
                                
                                <Button fx:id="btnChangeVehicle" onAction="#handleChangeVehicle" text=" Змінити авто"
                                        style="-fx-background-color: transparent; -fx-border-color: #FF9800; -fx-border-width: 2; -fx-border-radius: 6; -fx-text-fill: #FF9800; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;">
                                    <tooltip>
                                        <Tooltip text="Змінити автомобіль поїздки (з перерахунком палива)" />
                                    </tooltip>
                                </Button>
                                
                                <Button fx:id="btnGoogleMaps" onAction="#handleExportToMaps" text=" Google Maps"
                                        style="-fx-background-color: transparent; -fx-border-color: #4285F4; -fx-border-width: 2; -fx-border-radius: 6; -fx-text-fill: #4285F4; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;">
                                    <tooltip>
                                        <Tooltip text="Відкрити маршрут у Google Maps" />
                                    </tooltip>
                                </Button>
                                
                                <Button fx:id="btnDelete" onAction="#handleDelete" text=" Видалити"
                                        style="-fx-background-color: #FF5252; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;">
                                    <tooltip>
                                        <Tooltip text="Видалити поїздку" />
                                    </tooltip>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: #F5F5F5;">
            <content>
                <VBox spacing="20" style="-fx-padding: 20;">
                    <children>
                        <!-- Grid of Cards -->
                        <GridPane hgap="20" vgap="20">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            
                            <!-- Клієнт Card -->
                            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <children>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="" style="-fx-font-size: 20px;" />
                                        <Label text="Клієнт" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                    </HBox>
                                    <Separator style="-fx-background-color: #E0E0E0;" />
                                    
                                    <GridPane hgap="10" vgap="8">
                                        <columnConstraints>
                                            <ColumnConstraints hgrow="NEVER" minWidth="120" />
                                            <ColumnConstraints hgrow="ALWAYS" />
                                        </columnConstraints>
                                        
                                        <Label text="ПІБ / Назва:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="lblCustomerName" text="—" style="-fx-font-weight: bold; -fx-text-fill: #212121;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        
                                        <Label text="Email:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="lblCustomerEmail" text="—" style="-fx-text-fill: #212121;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        
                                        <Label text="Телефон:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <Label fx:id="lblCustomerPhone" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    </GridPane>
                                </children>
                            </VBox>
                            
                            <!-- Маршрут Card -->
                            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <children>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="" style="-fx-font-size: 20px;" />
                                        <Label text="Маршрут" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                    </HBox>
                                    <Separator style="-fx-background-color: #E0E0E0;" />
                                    
                                    <VBox spacing="8" fx:id="vboxRoute">
                                        <!-- Will be populated dynamically -->
                                    </VBox>
                                </children>
                            </VBox>
                            
                            <!-- Транспорт Card -->
                            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <children>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="" style="-fx-font-size: 20px;" />
                                        <Label text="Транспорт" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                    </HBox>
                                    <Separator style="-fx-background-color: #E0E0E0;" />
                                    
                                    <GridPane hgap="10" vgap="8">
                                        <columnConstraints>
                                            <ColumnConstraints hgrow="NEVER" minWidth="120" />
                                            <ColumnConstraints hgrow="ALWAYS" />
                                        </columnConstraints>
                                        
                                        <Label text="Автомобіль:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="lblVehicleName" text="—" style="-fx-font-weight: bold; -fx-text-fill: #212121;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        
                                        <Label text="Тип пального:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="lblFuelType" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        
                                        <Label text="Водій:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <Label fx:id="lblDriverName" text="—" style="-fx-text-fill: #212121;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        
                                        <Label text="Телефон водія:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <Label fx:id="lblDriverPhone" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    </GridPane>
                                </children>
                            </VBox>
                            
                            <!-- Планові показники Card -->
                            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <children>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="" style="-fx-font-size: 20px;" />
                                        <Label text="Планові показники" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                    </HBox>
                                    <Separator style="-fx-background-color: #E0E0E0;" />
                                    
                                    <VBox spacing="8" fx:id="vboxPlanned">
                                        <!-- Will be populated dynamically -->
                                    </VBox>
                                </children>
                            </VBox>
                            
                            <!-- Фактичні показники Card (if exists) -->
                            <VBox fx:id="cardActual" spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="2" visible="false" managed="false">
                                <children>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="" style="-fx-font-size: 20px;" />
                                        <Label text="Фактичні показники" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;" />
                                    </HBox>
                                    <Separator style="-fx-background-color: #E0E0E0;" />
                                    
                                    <VBox spacing="8" fx:id="vboxActual">
                                        <!-- Will be populated dynamically -->
                                    </VBox>
                                </children>
                            </VBox>
                            
                            <!-- Час Card -->
                            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <children>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text="" style="-fx-font-size: 20px;" />
                                        <Label text="Час" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                    </HBox>
                                    <Separator style="-fx-background-color: #E0E0E0;" />
                                    
                                    <GridPane hgap="10" vgap="8">
                                        <columnConstraints>
                                            <ColumnConstraints hgrow="NEVER" minWidth="150" />
                                            <ColumnConstraints hgrow="ALWAYS" />
                                        </columnConstraints>
                                        
                                        <Label text="Плановий початок:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="lblPlannedStart" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        
                                        <Label text="Плановий кінець:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="lblPlannedEnd" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        
                                        <Label text="Фактичний початок:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <Label fx:id="lblActualStart" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        
                                        <Label text="Фактичний кінець:" style="-fx-text-fill: #757575;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <Label fx:id="lblActualEnd" text="—" style="-fx-text-fill: #212121;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    </GridPane>
                                </children>
                            </VBox>
                        </GridPane>
                        
                        <!-- Додаткова інформація Card (full width) -->
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                            <children>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="" style="-fx-font-size: 20px;" />
                                    <Label text="Додаткова інформація" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;" />
                                </HBox>
                                <Separator style="-fx-background-color: #E0E0E0;" />
                                
                                <GridPane hgap="20" vgap="12" fx:id="gridAdditional">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="33" />
                                        <ColumnConstraints percentWidth="33" />
                                        <ColumnConstraints percentWidth="34" />
                                    </columnConstraints>
                                    <!-- Will be populated dynamically -->
                                </GridPane>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
