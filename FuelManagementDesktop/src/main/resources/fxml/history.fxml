<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fuelmanagement.controller.HistoryController"
            style="-fx-background-color: #F5F7FA;">
    <top>
        <VBox style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <children>
                <!-- Back button -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 20;">
                    <children>
                        <Button fx:id="btnBackToMenu" onAction="#handleBackToMenu"
                                text="← Назад до меню"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #238A90;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 14px;
                                       -fx-background-radius: 8;
                                       -fx-border-color: #238A90;
                                       -fx-border-width: 1.5;
                                       -fx-border-radius: 8;
                                       -fx-padding: 8 16;
                                       -fx-cursor: hand;">
                            <tooltip>
                                <Tooltip text="Повернутися до головного меню" />
                            </tooltip>
                        </Button>
                    </children>
                </HBox>
                
                <!-- Title and subtitle -->
                <VBox spacing="5" style="-fx-padding: 0 20 20 20;">
                    <children>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Історія поїздок" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- Compact Filters Panel -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <children>
                    <!-- First row: filters -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <children>
                            <Button fx:id="btnRefresh" onAction="#handleRefresh" text="🔄 Оновити"
                                    style="-fx-background-color: #238A90; -fx-text-fill: white; -fx-font-weight: 600; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 13px;">
                                <tooltip>
                                    <Tooltip text="Оновити список поїздок з бази даних" />
                                </tooltip>
                            </Button>
                            
                            <ComboBox fx:id="cmbStatusFilter" prefWidth="160" promptText="Всі статуси"
                                      style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;">
                                <tooltip>
                                    <Tooltip text="Фільтрувати поїздки за статусом" />
                                </tooltip>
                            </ComboBox>
                            
                            <DatePicker fx:id="dpFromDate" prefWidth="150" promptText="Від дати"
                                        style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;">
                                <tooltip>
                                    <Tooltip text="Показати поїздки починаючи з цієї дати" />
                                </tooltip>
                            </DatePicker>
                            
                            <CheckBox fx:id="chkShowOnlyAssigned" text="Тільки з призначеними водіями"
                                      style="-fx-text-fill: #2C3E50; -fx-font-size: 13px;">
                                <tooltip>
                                    <Tooltip text="Показати лише поїздки, до яких призначені водії" />
                                </tooltip>
                            </CheckBox>
                            
                            <Region HBox.hgrow="ALWAYS" />
                            
                            <ProgressIndicator fx:id="progressLoading" prefHeight="20" prefWidth="20" visible="false" />
                        </children>
                    </HBox>
                    
                    <!-- Second row: search and clear -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <children>
                            <TextField fx:id="txtSearch" promptText="🔍 Пошук по номеру, клієнту, адресам..." HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #F5F7FA; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12; -fx-font-size: 13px;">
                                <tooltip>
                                    <Tooltip text="Швидкий пошук: введіть номер поїздки, ім'я замовника або адресу" />
                                </tooltip>
                            </TextField>
                            
                            <Button onAction="#handleClearFilters" text="✕ Очистити фільтри"
                                    style="-fx-background-color: transparent; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 6; -fx-text-fill: #7F8C8D; -fx-font-weight: 500; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 13px;">
                                <tooltip>
                                    <Tooltip text="Скинути всі застосовані фільтри" />
                                </tooltip>
                            </Button>
                        </children>
                    </HBox>
                </children>
            </VBox>

            <!-- Results count and pagination -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 5;">
                <children>
                    <Label fx:id="lblResultsCount" text="Знайдено поїздок: 0" style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D; -fx-font-weight: 500;" />
                    
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <!-- Pagination controls -->
                    <HBox fx:id="paginationBox" alignment="CENTER_RIGHT" spacing="8">
                        <children>
                            <Button fx:id="btnFirstPage" text="⏮" 
                                    style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand; -fx-font-size: 12px;">
                                <tooltip>
                                    <Tooltip text="Перша сторінка" />
                                </tooltip>
                            </Button>
                            <Button fx:id="btnPrevPage" text="◀ Назад" 
                                    style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand; -fx-font-size: 12px;">
                                <tooltip>
                                    <Tooltip text="Попередня сторінка" />
                                </tooltip>
                            </Button>
                            <Label fx:id="lblPageInfo" text="Сторінка 1 з 1" 
                                   style="-fx-font-size: 13px; -fx-text-fill: #2C3E50; -fx-font-weight: 500; -fx-padding: 0 12;" />
                            <Button fx:id="btnNextPage" text="Вперед ▶" 
                                    style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand; -fx-font-size: 12px;">
                                <tooltip>
                                    <Tooltip text="Наступна сторінка" />
                                </tooltip>
                            </Button>
                            <Button fx:id="btnLastPage" text="⏭" 
                                    style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand; -fx-font-size: 12px;">
                                <tooltip>
                                    <Tooltip text="Остання сторінка" />
                                </tooltip>
                            </Button>
                        </children>
                    </HBox>
                </children>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblTrips" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <columns>
                    <TableColumn fx:id="colTripNumber" prefWidth="100" text="№ Поїздки" />
                    <TableColumn fx:id="colStatus" prefWidth="140" text="Статус" />
                    <TableColumn fx:id="colRequester" prefWidth="140" text="Замовник" />
                    <TableColumn fx:id="colRoute" prefWidth="250" text="Маршрут" />
                    <TableColumn fx:id="colVehicle" prefWidth="140" text="Автомобіль" />
                    <TableColumn fx:id="colDriver" prefWidth="140" text="Водій" />
                    <TableColumn fx:id="colDistance" prefWidth="80" text="Км (план)" />
                    <TableColumn fx:id="colActualDistance" prefWidth="80" text="Км (факт)" />
                    <TableColumn fx:id="colDeviation" prefWidth="80" text="Відх. %" />
                    <TableColumn fx:id="colActualStart" prefWidth="130" text="Початок" />
                    <TableColumn fx:id="colActualEnd" prefWidth="130" text="Кінець" />
                    <TableColumn fx:id="colFuel" prefWidth="70" text="Літри" />
                    <TableColumn fx:id="colRefrigerator" prefWidth="80" text="Холод-к %" />
                    <TableColumn fx:id="colCreated" prefWidth="120" text="Створено" />
                    <TableColumn fx:id="colActions" prefWidth="120" text="Дії" sortable="false" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <placeholder>
                    <Label text="Поїздки не знайдено або фільтри не дали результатів" style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D;" />
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <!-- Нижня панель з підказками -->
        <!-- <VBox>
            <children>
                <Separator style="-fx-background-color: #238A90; -fx-pref-height: 2;" />
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: rgba(255,255,255,0.95); -fx-padding: 18 20;">
                    <children>
                        <Label text="💡 Підказки: Використовуйте фільтри для швидкого пошуку • Клікніть на поездку для деталей • Статистика оновлюється автоматично"
                               style="-fx-font-size: 12.5px; -fx-text-fill: #238A90; -fx-font-weight: 500;" wrapText="true" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="© 2025 Система обліку палива" style="-fx-font-size: 11.5px; -fx-text-fill: #238A90; -fx-font-weight: bold;" />
                    </children>
                </HBox>
            </children>
        </VBox> -->
    </bottom>
</BorderPane>