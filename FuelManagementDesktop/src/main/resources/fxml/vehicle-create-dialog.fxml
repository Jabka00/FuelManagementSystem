<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.fuelmanagement.controller.VehicleCreateDialogController"
            style="-fx-background-color: linear-gradient(to bottom, #F8FFFE, #E8F8F8);"
            prefWidth="600.0" prefHeight="650.0">

    <top>
        <VBox spacing="10.0"
              style="-fx-background-color: linear-gradient(to bottom, #238A90, #238A90);
                     -fx-background-radius: 0 0 20 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 2);">
            <padding>
                <Insets top="20.0" bottom="20.0" left="30.0" right="30.0" />
            </padding>
            <children>
                <Label text="➕ Додати новий автомобіль" textFill="WHITE"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" 
                    style="-fx-background-color: transparent; -fx-border-color: transparent;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="20.0">
                    <padding>
                        <Insets top="20.0" bottom="20.0" left="30.0" right="30.0" />
                    </padding>

                    <!-- Основна інформація -->
                    <VBox spacing="15.0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                        <children>
                            <Label text=" Основна інформація"
                                   style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #238A90;" />

                            <GridPane hgap="15.0" vgap="12.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="150.0" prefWidth="150.0" />
                                    <ColumnConstraints hgrow="ALWAYS" />
                                </columnConstraints>

                                <Label text="Номерний знак:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtLicensePlate" promptText="AA1234BB" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Модель:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtModel" promptText="Toyota Camry" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Тип палива:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                                       style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="cmbFuelType" promptText="Оберіть тип палива" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Статус:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                                       style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="cmbStatus" value="Активний" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Ємність баку (л):" GridPane.columnIndex="0" GridPane.rowIndex="4"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtTankCapacity" promptText="60.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label text="Початковий пробіг (км):" GridPane.columnIndex="0" GridPane.rowIndex="5"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtOdometer" promptText="0" text="0" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                <Label text="Холодильник:" GridPane.columnIndex="0" GridPane.rowIndex="6"
                                       style="-fx-font-weight: bold;" />
                                <CheckBox fx:id="chkHasRefrigerator" GridPane.columnIndex="1" GridPane.rowIndex="6"
                                         text="Є холодильник"
                                         style="-fx-font-size: 14px;" />
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- Норми витрат (літо) -->
                    <VBox spacing="15.0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                        <children>
                            <Label text="☀ Норми витрат палива (літо)"
                                   style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #F39C12;" />

                            <GridPane hgap="15.0" vgap="12.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="150.0" prefWidth="150.0" />
                                    <ColumnConstraints hgrow="ALWAYS" />
                                </columnConstraints>

                                <Label text="Місто (л/км):" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtCityRateSummer" promptText="0.085" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Траса (л/км):" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtHighwayRateSummer" promptText="0.065" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- Норми витрат (зима) -->
                    <VBox spacing="15.0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                        <children>
                            <Label text=" Норми витрат палива (зима)"
                                   style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #3498DB;" />

                            <GridPane hgap="15.0" vgap="12.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="150.0" prefWidth="150.0" />
                                    <ColumnConstraints hgrow="ALWAYS" />
                                </columnConstraints>

                                <Label text="Місто (л/км):" GridPane.columnIndex="0" GridPane.rowIndex="0"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtCityRateWinter" promptText="0.095" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Траса (л/км):" GridPane.columnIndex="0" GridPane.rowIndex="1"
                                       style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtHighwayRateWinter" promptText="0.075" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- Примітки -->
                    <VBox spacing="10.0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 12;
                                 -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                        <children>
                            <Label text=" Примітки"
                                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #238A90;" />
                            <TextArea fx:id="txtNotes" promptText="Додаткова інформація про автомобіль..."
                                     prefRowCount="3" wrapText="true" />
                        </children>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0"
              style="-fx-background-color: rgba(255,255,255,0.8);
                     -fx-background-radius: 20 20 0 0;
                     -fx-padding: 20;">
            <children>
                <Label fx:id="lblStatus" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;" HBox.hgrow="ALWAYS" />

                <Button fx:id="btnCancel" onAction="#handleCancel"
                        text="Скасувати" minWidth="120.0" minHeight="40.0"
                        style="-fx-background-color: #95A5A6;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;" />

                <Button fx:id="btnSave" onAction="#handleSave"
                        text="Додати автомобіль" minWidth="150.0" minHeight="40.0"
                        style="-fx-background-color: linear-gradient(to bottom, #27AE60, #229954);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(39, 174, 96, 0.4), 6, 0, 0, 2);" />
            </children>
        </HBox>
    </bottom>
</BorderPane>

