<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.fuelmanagement.controller.DriverCreateDialogController"
            style="-fx-background-color: linear-gradient(to bottom, #F8FFFE, #E8F8F8);"
            prefWidth="800.0" prefHeight="650.0">

    <top>
        <VBox spacing="10.0"
              style="-fx-background-color: linear-gradient(to bottom, #238A90, #238A90);
                     -fx-background-radius: 0 0 20 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 2);">
            <padding>
                <Insets top="20.0" bottom="20.0" left="30.0" right="30.0" />
            </padding>
            <children>
                <Label fx:id="lblTitle" text="➕ Додати водія" textFill="WHITE"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            </children>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.5" style="-fx-background-color: transparent;">
            <!-- Левая часть: Форма создания/редактирования -->
            <VBox spacing="15.0" style="-fx-padding: 20;">
                <Label text=" Дані водія"
                       style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #238A90;" />
                
                <VBox spacing="12.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                    <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="ПІБ:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtFullName" promptText="Іванов Іван Іванович" 
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Телефон:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtPhone" promptText="+380501234567" 
                                   GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </GridPane>
                    
                    <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnSave" text="💾 Зберегти" minWidth="120.0" minHeight="35.0"
                                style="-fx-background-color: linear-gradient(to bottom, #27AE60, #229954);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 14px;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(39, 174, 96, 0.4), 4, 0, 0, 2);" />
                        
                        <Button fx:id="btnClear" text="Очистити" minWidth="100.0" minHeight="35.0"
                                style="-fx-background-color: #95A5A6;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 14px;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;" />
                    </HBox>
                    
                    <Label fx:id="lblStatus" text="" style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D; -fx-padding: 5 0 0 0;" />
                </VBox>
            </VBox>
            
            <!-- Правая часть: Список водителей -->
            <VBox spacing="15.0" style="-fx-padding: 20;">
                <Label text=" Список водіїв"
                       style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #238A90;" />
                
                <VBox spacing="10.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-padding: 15;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                    <TableView fx:id="tableDrivers" prefHeight="400.0"
                               style="-fx-text-fill: black; 
                                      -fx-font-size: 14px;">
                        <columns>
                            <TableColumn fx:id="colName" text="ПІБ" prefWidth="200.0" 
                                        style="-fx-text-fill: black; -fx-alignment: CENTER-LEFT;" />
                            <TableColumn fx:id="colPhone" text="Телефон" prefWidth="150.0" 
                                        style="-fx-text-fill: black; -fx-alignment: CENTER;" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15.0"
              style="-fx-background-color: rgba(255,255,255,0.8);
                     -fx-background-radius: 20 20 0 0;
                     -fx-padding: 20;">
            <children>
                <Region HBox.hgrow="ALWAYS" />
                
                <Button fx:id="btnClose" text="Закрити" minWidth="120.0" minHeight="40.0"
                        style="-fx-background-color: #95A5A6;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
