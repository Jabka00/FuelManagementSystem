<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_trip_number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Поїздка: #123"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_route"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Маршрут: Київ → Харків"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Статус: Призначено"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_vehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Автомобіль: АА1234АА"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="8dp" />
                    
                <TextView
                    android:id="@+id/tv_driver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Водій: Іваненко Іван Іванович"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Відстань"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_planned_distance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Планова відстань: 100 км"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_actual_distance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Фактична відстань: 105 км"
                    android:textSize="14sp"
                    android:textColor="@color/success"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Час"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_start_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Час початку: 12.08.2025 10:30"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_end_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Час закінчення: 12.08.2025 15:45"
                    android:textSize="14sp"
                    android:textColor="@color/success"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Пробіг автомобіля"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_current_odometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Поточний пробіг автомобіля: 150000 км"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_start_odometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Початковий пробіг: 150000 км"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_end_odometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Кінцевий пробіг: 150105 км"
                    android:textSize="14sp"
                    android:textColor="@color/success"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_start_trip"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Зафіксувати виїзд водія"
                android:textSize="16sp"
                android:textColor="@color/on_primary"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button" />

            <Button
                android:id="@+id/btn_finish_trip"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Зафіксувати приїзд водія"
                android:textSize="16sp"
                android:textColor="@color/on_primary"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>