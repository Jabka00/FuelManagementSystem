<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_card"
            android:padding="24dp"
            android:layout_marginBottom="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Система обліку палива\nПеревірка підключення...."
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_selected_driver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Пост охорони\nВедіть облік виїздів і приїздів водіїв"
                android:textSize="15sp"
                android:padding="16dp"
                android:background="@drawable/bg_info_badge"
                android:textColor="@color/on_primary_container"
                android:gravity="center"
                android:visibility="visible" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Швидкі дії"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_create_trip"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Створити поїздку"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary"
                    android:backgroundTint="@color/primary"
                    android:layout_marginBottom="12dp"
                    android:drawablePadding="8dp"
                    style="@style/Widget.Material3.Button" />

                <Button
                    android:id="@+id/btn_view_trips"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Список поїздок"
                    android:textSize="17sp"
                    android:textColor="@color/on_primary"
                    android:backgroundTint="@color/primary"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.Material3.Button" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_variant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <Button
                    android:id="@+id/btn_settings"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Налаштування"
                    android:textSize="16sp"
                    android:textColor="@color/primary"
                    android:backgroundTint="@android:color/transparent"
                    android:elevation="0dp"
                    style="@style/Widget.Material3.Button.TextButton" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Режим: Пост охорони\nВерсія 2.0"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="@color/on_surface_variant"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
